# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys
# At least one of these is required.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# LLM Configuration — global overrides for all agents
#
# These override the defaults in config/llm_config.yaml.
# Leave blank (or omit) to rely solely on llm_config.yaml.
# For per-agent overrides, edit the `agents:` section of llm_config.yaml
# or add an `llm_config:` block to the agent entry in config/agents.yaml.
#
# Supported providers: openai | anthropic | ollama | azure | groq | mistral
#                      cohere | bedrock | huggingface | vertexai
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# ─────────────────────────────────────────────────────────────────────────────
# Embedder — used for Crew-level memory (vector search)
# Leave blank to use the defaults from config/llm_config.yaml embedder section.
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────────────
# Free data source API keys
# ─────────────────────────────────────────────────────────────────────────────
# Federal Reserve data — use "demo" for rate-limited free access
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=demo

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
MAX_WORKERS=4
CACHE_TTL=3600

# ─────────────────────────────────────────────────────────────────────────────
# Data Sources (set to false to disable individual sources)
# ─────────────────────────────────────────────────────────────────────────────
YAHOO_FINANCE_ENABLED=true
SEC_EDGAR_ENABLED=true
FRED_ENABLED=true
RSS_FEEDS_ENABLED=true
WEB_SCRAPING_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ─────────────────────────────────────────────────────────────────────────────
# Report output
# ─────────────────────────────────────────────────────────────────────────────
REPORT_FORMAT=json
REPORT_TEMPLATE=default
REPORT_OUTPUT_DIR=./reports

# ─────────────────────────────────────────────────────────────────────────────
# Crew output log (captures all agent steps for debugging / audit)
# ─────────────────────────────────────────────────────────────────────────────
CREW_LOG_FILE=logs/crew_output.log

# ─────────────────────────────────────────────────────────────────────────────
# Database / Cache
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./stock_analysis.db
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# Security — MUST be changed in production (non-DEBUG) deployments
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Monitoring
# ─────────────────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Notifications
# ─────────────────────────────────────────────────────────────────────────────
# EMAIL_ENABLED=false
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_FROM=your_email@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Webhooks
# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK_ENABLED=false
# WEBHOOK_URL=https://your-webhook-url.com/stock-analysis
# WEBHOOK_SECRET=your_webhook_secret
